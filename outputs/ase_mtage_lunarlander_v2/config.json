{
  "method": {
    "name": "ASE-MTAGE",
    "k_candidates": 3,
    "max_rounds": 10,
    "selected_long_train_per_round": 1,
    "use_short_training": false
  },
  "training": {
    "env_id": "LunarLander-v2",
    "full_timesteps": 500000,
    "eval_interval": 50000,
    "eval_episodes_per_interval": 5,
    "final_eval_episodes": 50,
    "seed": 42
  },
  "llm": {
    "enabled": true,
    "provider": "deepseek",
    "model": "deepseek-reasoner",
    "api_key_env": "DEEPSEEK_API_KEY",
    "api_key": "***MASKED***",
    "base_url": "https://api.deepseek.com",
    "timeout_seconds": 600,
    "max_tokens": 4096,
    "fallback_on_error": false,
    "temperature": {
      "env_perception": 0.2,
      "trajectory_judge": 0.2,
      "analyzer": 0.4,
      "mutator": 0.6,
      "reflector": 0.3
    }
  },
  "trajectory_memory": {
    "min_trajectories": 20,
    "min_high_confidence_trajectories": 12,
    "label_confidence_threshold": 0.75,
    "use_ambiguous_for_tage": false
  },
  "output_root": "outputs",
  "experiment_name": "ase_mtage_lunarlander_v2"
}
